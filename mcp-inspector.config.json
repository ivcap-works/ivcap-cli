{
  "mcpServers": {
    "default-server": {
      "type": "stdio",
      "command": "./ivcap",
      "args": [
        "mcp"
      ]
    },
    "sse-8077": {
      "type": "sse",
      "url": "http://localhost:8077/mcp"
    },
    "homebrew": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/ivcap",
      "args": [
        "mcp"
      ]
    }
  }
}